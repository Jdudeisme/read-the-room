# Copy to .env and adjust. All values shown are the defaults.

# Input device: name substring or integer index (see `read-the-room --list-devices`).
# Empty = system default input.
RTR_INPUT_DEVICE=

# Analysis windowing (seconds). 5s window, 2s hop per the M1 spec.
RTR_WINDOW_S=5.0
RTR_HOP_S=2.0

# Emotion layer (audeering wav2vec2 valence/arousal).
RTR_EMOTION_ENABLED=1
RTR_EMOTION_MODEL=audeering/wav2vec2-large-robust-12-ft-emotion-msp-dim
# Minimum seconds between emotion inferences. Raise (e.g. 6.0) if the
# benchmark shows the demo machine can't keep up at every hop.
RTR_EMOTION_MIN_INTERVAL_S=2.0
# Speech ratio below this skips emotion inference for the window (VAD gate).
RTR_EMOTION_MIN_SPEECH_RATIO=0.2

# Headcount layer (ECAPA speaker embeddings + clustering, M2).
RTR_HEADCOUNT_ENABLED=1
RTR_HEADCOUNT_MODEL=speechbrain/spkrec-ecapa-voxceleb
# Minimum seconds between headcount passes. THE pre-approved fallback if
# `bench_headcount.py --concurrent` fails its gate: set this to 4.0
# (headcount updates every other hop; staleness reports it honestly).
RTR_HEADCOUNT_MIN_INTERVAL_S=2.0
# Speech ratio below this skips headcount for the window (same VAD gate).
RTR_HEADCOUNT_MIN_SPEECH_RATIO=0.2
# Rolling embedding evidence horizon (seconds) and entry cap.
RTR_HEADCOUNT_BUFFER_S=90.0
# Cosine-distance cut for speaker clustering. Lower = more clusters.
RTR_HEADCOUNT_CLUSTER_THRESHOLD=0.40
# Bucket smoothing: EMA time constant (log2 space) and the number of
# consecutive agreeing updates required before the bucket changes.
RTR_HEADCOUNT_SMOOTH_TAU_S=20.0
RTR_HEADCOUNT_HYSTERESIS_K=3

# Mapping layer (M3): RoomState -> shadow Recommendation.
# Valence/arousal band cutoffs (2020-seeded). Band is "high" strictly above
# *_HIGH, "low" at or below *_LOW, "mid" between.
RTR_MAPPING_VALENCE_LOW=-0.25
RTR_MAPPING_VALENCE_HIGH=0.25
RTR_MAPPING_AROUSAL_LOW=-0.25
RTR_MAPPING_AROUSAL_HIGH=0.25
# Hysteresis: minimum seconds between emitted recommendations. A material
# change (mood quadrant / headcount bucket / energy action) is ALSO required.
RTR_MAPPING_MIN_DWELL_S=30.0
# Low-confidence guard: below these the mapper emits a low-confidence "hold"
# instead of guessing. Headcount confidence <= ~0.3 means the collapsed/crowd
# regime.
RTR_MAPPING_MIN_SPEECH_RATIO=0.1
RTR_MAPPING_MIN_HEADCOUNT_CONFIDENCE=0.35
RTR_MAPPING_GUARD_CONFIDENCE=0.15
# Short-horizon valence/arousal trend that selects the energy action
# (raise / lower / hold — match the room's direction).
RTR_MAPPING_TREND_HORIZON_S=60.0
RTR_MAPPING_TREND_SLOPE_THRESHOLD=0.10
# How far target valence/arousal lead the current reading in the trend
# direction.
RTR_MAPPING_TARGET_LEAD=0.15

# Torch CPU threads. 0 = let torch decide.
RTR_TORCH_THREADS=0

# Use the OS certificate store for HTTPS (model downloads). Needed behind
# TLS-intercepting proxies/AV. Set 0 to use certifi's bundle instead.
RTR_OS_TRUSTSTORE=1

# Optional: relocate the HuggingFace model cache (~1.2 GB for the emotion model).
# HF_HOME=
